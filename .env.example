# ================= Service =================
IMAGE_SERVICE_PORT=3100
LOG_LEVEL=info

# ================= FAL Platform =================
# Used by: flux, flux-2-pro, hunyuan, qwen, dreamomni2
FAL_KEY=

# ================= Google Gemini =================
# Used by: nano-banana, nano-banana-pro, nano-banana-2
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ================= Volcengine ARK =================
# Used by: seedream, seedream45
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com

# ================= OpenAI =================
# Used by: openai, openai-mini, openai-15
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ================= Storage =================
# LOCAL_STORAGE_PATH: directory inside the container where images are saved
# LOCAL_FILE_URL_PREFIX: public URL prefix used in returned image URLs
LOCAL_STORAGE_PATH=/data/images
LOCAL_FILE_URL_PREFIX=http://localhost:3100/images
