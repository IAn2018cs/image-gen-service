# ================= Service =================
IMAGE_SERVICE_PORT=3100
LOG_LEVEL=info

# ================= FAL Platform =================
# Used by: flux, flux-2-pro, hunyuan, qwen, dreamomni2
FAL_KEY=

# ================= Google Gemini =================
# Used by: gemini, gemini3, gemini31flash
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ================= Volcengine ARK =================
# Used by: seedream, seedream45
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com

# ================= OpenAI =================
# Used by: openai, openai-mini, openai-15
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ================= Storage =================
STORAGE_TYPE=local_mount
NAS_MOUNT_PATH=/mnt/nas/images
NAS_FILE_URL_PREFIX=http://192.168.1.100:8080/images

# ================= NAS SMB Mount (Docker volume) =================
NAS_HOST=192.168.1.100
NAS_USER=your_username
NAS_PASSWORD=your_password
NAS_PORT=445
NAS_SHARE_PATH=shared/images
