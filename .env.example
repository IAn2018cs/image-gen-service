# ================= Service =================
IMAGE_SERVICE_PORT=3100
LOG_LEVEL=info

# ================= FAL Platform =================
# Used by: flux, flux-2-pro, hunyuan, qwen, dreamomni2
FAL_KEY=

# ================= Google Gemini =================
# Used by: nano-banana, nano-banana-pro, nano-banana-2
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# ================= Volcengine ARK =================
# Used by: seedream, seedream45
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com

# ================= OpenAI =================
# Used by: openai, openai-mini, openai-15
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ================= Storage =================
# IMAGE_BASE_URL: public base URL of this service (used to construct image URLs)
# Change to your server's public host/IP when deploying externally
IMAGE_BASE_URL=http://localhost:3100

# ================= MCP Server =================
# Set MCP_PORT to enable the MCP HTTP server alongside the REST API
# Exposes tools: generate_image, edit_image, list_models
# HTTP endpoint: http://localhost:<MCP_PORT>/mcp
# SSE endpoint:  http://localhost:<MCP_PORT>/sse
# MCP_PORT=3101
